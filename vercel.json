{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/agent-app/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/admin-app/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/icon/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}